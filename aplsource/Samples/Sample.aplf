Sample;start;cr

 ‚çù Topic created with
 ‚çù
 ‚çù     kafka-topics.sh \
 ‚çù       --bootstrap-server localhost:9092 \
 ‚çù       --create --topic "animals" \
 ‚çù       --partitions 3

 ‚çù Call to Init function
 Init 'path/to/dir/housing/kafka/shared/lib'

 consumer‚Üê‚éïNEW Consumer

 consumer.configure'bootstrap.servers' 'localhost:9092' ‚çù'grs3550.insight.local:9092'
 consumer.configure'client.id' 'martina'‚çù'bhcgrs3550'
 consumer.configure'group.id' 'dyalog'

 ‚çù Manually create a new topic partition list l
 l‚Üêconsumer.topic_partition
 ‚çù Set topics (and partition, wich will be ignored when subscribing to it)
 consumer.set_topic_partition l'animals' 0
 consumer.subscribe_topic_partition l
 ‚éïDL 5

 bb‚Üê‚éïNEW #.Record('animals' 'Blackbird' 'birds')
 so‚Üê‚éïNEW #.Record('animals' 'Sole' 'fish')
 ef‚Üê‚éïNEW #.Record('animals' 'Elefant' 'mamal')

 producer‚Üê‚éïNEW Producer
 producer.configure'bootstrap.servers' 'localhost:9092'‚çù'grs3550.insight.local:9092'
 producer.configure'client.id' 'martina'‚çù'bhc'

 producer.produce_record bb
 producer.produce_record so
 producer.produce_record ef

 ‚éïDL 1
 producer.delivery_report 13

 start‚Üê3‚äÉ‚éïAI
 :While 1
     cr‚Üêconsumer.consume_record
     :If 1=‚äÉcr
     :AndIf 20000>(3‚äÉ‚éïAI)-start
         ‚éïDL 0.2
         :Continue
     :ElseIf 0=‚äÉcr
         (2‚äÉcr).(Topic Payload Key Partition)
         start‚Üê0
     :Else
         cr
         :Leave
     :EndIf
 :EndWhile

 ‚éïEX'producer'
 ‚éïEX'consumer'
